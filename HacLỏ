local function HoverOnNPC()
    if not hrp or getgenv().PlayerDead then return end

    if IsAllBossMode() then
        HoverOnNPC_AllBoss()
        return
    end

    local list = GetFilterList()
    local hasFilter = #list > 0

    local target, humanoid = GetNearestNPC()

    if not target then
        HoldHover()
        return
    end

    local primaryPart = target.PrimaryPart or target:FindFirstChild("HumanoidRootPart")
    if not primaryPart then
        HoldHover()
        return
    end

    TryEquipCombat()
    EnableHover(hrp)
    local bp = hrp:FindFirstChild("BodyPosition")

    while getgenv().AutoNPC and not getgenv().PlayerDead and humanoid and humanoid.Health > 0 do
        if not hrp then break end
        primaryPart = target.PrimaryPart or target:FindFirstChild("HumanoidRootPart")
        if not primaryPart then break end
        MoveTowards(primaryPart.Position)
    end

    if not getgenv().AutoNPC or getgenv().PlayerDead then
        DisableHover(hrp)
        return
    end

    if hasFilter then
        local index = getgenv().TargetIndex
        getgenv().TargetIndex = (index % #list) + 1
        HoldHover()
        while getgenv().AutoNPC and not getgenv().PlayerDead do
            task.wait(0.5)
            local newTarget, _ = GetNearestNPC()
            if newTarget then break end
        end
    else
        HoldHover()
    end
end

