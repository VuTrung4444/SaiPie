local function MoveTowards(targetPos)
    if not hrp then return end
    local desiredPos = targetPos + Vector3.new(0, HoverHeight, 0)
    local distance = (hrp.Position - desiredPos).Magnitude

    if distance > 50 then
        local direction = desiredPos - hrp.Position
        local dt = 0.01 -- dt cố định thay vì dùng giá trị trả về từ task.wait
        local step = math.min(MoveSpeed * dt, distance)
        local nextPos = hrp.Position + direction.Unit * step
        hrp.Velocity = Vector3.zero
        hrp.AssemblyLinearVelocity = Vector3.zero
        if (targetPos - nextPos).Magnitude > 0.1 then
            hrp.CFrame = CFrame.new(nextPos, targetPos)
        else
            hrp.CFrame = CFrame.new(nextPos)
        end
        local bp = hrp:FindFirstChild("BodyPosition")
        if bp then bp.Position = nextPos end
        task.wait(dt)
    else
        local bp = hrp:FindFirstChild("BodyPosition")
        if bp then bp.Position = desiredPos end
        if (targetPos - hrp.Position).Magnitude > 0.1 then
            hrp.CFrame = CFrame.new(hrp.Position, targetPos)
        end
        hrp.Velocity = Vector3.zero
        hrp.AssemblyLinearVelocity = Vector3.zero
        task.wait(0.01)
    end
end

