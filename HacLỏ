local function FuzzyScore(query, name)
    query = query:lower()
    name = name:lower()
    if name:find(query, 1, true) then return 1000 - #name end
    local score = 0
    local qi = 1
    for i = 1, #name do
        if qi <= #query and name:sub(i,i) == query:sub(qi,qi) then
            score = score + 1
            qi = qi + 1
        end
    end
    if qi <= #query then return -1 end
    return score
end

local function GetNearestNPC(maxDistance)
    if not hrp then return nil, nil end
    local npcsFolder = workspace:FindFirstChild("NPCs")
    if not npcsFolder then return nil, nil end

    local filter = getgenv().NPCFilter or ""
    local hasFilter = filter ~= ""
    maxDistance = maxDistance or 2000

    local target, humanoid = nil, nil
    local closestDistance = math.huge

    for _, npc in ipairs(npcsFolder:GetChildren()) do
        local h = npc:FindFirstChild("Humanoid")
        local primaryPart = npc.PrimaryPart or npc:FindFirstChild("HumanoidRootPart")
        if not (h and h.Health > 0 and primaryPart) then continue end

        local distance = (hrp.Position - primaryPart.Position).Magnitude
        if distance > maxDistance then continue end

        if hasFilter then
            local displayName = h.DisplayName ~= "" and h.DisplayName or npc.Name
            local score = FuzzyScore(filter, displayName)
            if score < 0 then continue end
        end

        if distance < closestDistance then
            closestDistance = distance
            target = npc
            humanoid = h
        end
    end
    return target, humanoid
end

local function HoldHover()
