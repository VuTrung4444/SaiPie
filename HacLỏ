local function HoverOnNPC_AllBoss()
    if not hrp or getgenv().PlayerDead then return end

    while getgenv().AutoNPC and not getgenv().PlayerDead and IsAllBossMode() do
        if not hrp then task.wait(0.5) continue end

        local npcsFolder = workspace:FindFirstChild("NPCs")
        if not npcsFolder then task.wait(1) continue end

        local target, targetHumanoid = nil, nil
        local bestDist = math.huge

        for _, bossName in ipairs(BossList) do
            local npc = npcsFolder:FindFirstChild(bossName)
            if npc and npc.ClassName == "Model" and hrp then
                local h = npc:FindFirstChildWhichIsA("Humanoid", true)
                if h and h.Health > 0 then
                    local pos = npc:GetPivot().Position
                    local d = (hrp.Position - pos).Magnitude
                    if d < bestDist then
                        bestDist = d
                        target = npc
                        targetHumanoid = h
                    end
                end
            end
        end

        if not target then
            local mobFilter = GetAllBossMobFilter()
            local npcsFolder2 = workspace:FindFirstChild("NPCs")
            local mobTarget = nil
            local mobBestDist = math.huge

            if npcsFolder2 and hrp and mobFilter ~= "" then
                for _, npc in ipairs(npcsFolder2:GetChildren()) do
                    if npc.ClassName == "Model" then
                        local h = npc:FindFirstChildWhichIsA("Humanoid", true)
                        if h and h.Health > 0 then
                            local displayName = h.DisplayName ~= "" and h.DisplayName or npc.Name
                            local score = FuzzyScore(mobFilter, displayName)
                            if score >= 0 then
                                local pos = npc:GetPivot().Position
                                local d = (hrp.Position - pos).Magnitude
                                if d < mobBestDist then
                                    mobBestDist = d
                                    mobTarget = npc
                                end
                            end
                        end
                    end
                end
            end

            if mobTarget then
                TryEquipCombat()
                EnableHover(hrp)
                local lastBossCheck = 0
                while getgenv().AutoNPC and not getgenv().PlayerDead and IsAllBossMode() do
                    if not hrp then break end

                    local now = tick()
                    if now - lastBossCheck >= 0.5 then
                        lastBossCheck = now
                        if HasAliveBoss() then break end
                    end

                    local mobH = mobTarget:FindFirstChildWhichIsA("Humanoid", true)
                    if not mobH or mobH.Health <= 0 then break end
                    if not mobTarget.Parent then break end

                    MoveTowards(mobTarget:GetPivot().Position)
                end
            else
                HoldHover()
                task.wait(0.5)
            end
            continue
        end

        TryEquipCombat()
        EnableHover(hrp)

        while getgenv().AutoNPC and not getgenv().PlayerDead and IsAllBossMode() do
            if not hrp then break end
            if not target.Parent then break end
            if not targetHumanoid or targetHumanoid.Health <= 0 then break end

            MoveTowards(target:GetPivot().Position)
        end

        if not getgenv().AutoNPC or getgenv().PlayerDead or not IsAllBossMode() then
            DisableHover(hrp)
            return
        end

        task.wait(0.1)
    end

    DisableHover(hrp)
end

